{
  "name": "brainctl",
  "version": "0.1.2",
  "description": "CLI environment manager for consistent AI workflows",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rorogogogo/brainctl.git"
  },
  "homepage": "https://github.com/Rorogogogo/brainctl#readme",
  "bugs": {
    "url": "https://github.com/Rorogogogo/brainctl/issues"
  },
  "bin": {
    "brainctl": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm test && npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "cli",
    "ai",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "fastmcp": "^3.34.0",
    "lucide-react": "^0.542.0",
    "picocolors": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "jose": "6.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
